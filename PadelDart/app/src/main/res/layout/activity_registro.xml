<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_padel_oscuro"
    android:padding="24dp"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTituloRegistro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Registrate en PadelDart"
            android:textColor="#B2F814"
            android:textSize="29dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.493"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSecPersonales"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="1. DATOS PERSONALES"
            android:textSize="25dp"

            android:textColor="#EDFFAC"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTituloRegistro" />

        <LinearLayout
            android:id="@+id/llPersonales"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@+id/tvSecPersonales">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Nombre"
                android:textColorHint="#EDFFAC"
                app:boxStrokeColor="@color/borde_padel">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Apellidos"
                android:textColorHint="#EDFFAC"
                app:boxStrokeColor="@color/borde_padel">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApellidos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="DNI / NIE"
                android:textColorHint="#EDFFAC"
                app:boxStrokeColor="@color/borde_padel">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDni"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Correo electrónico"
                android:textColorHint="#EDFFAC"
                app:boxStrokeColor="@color/borde_padel">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCorreoReg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Contraseña"
                android:textColorHint="#EDFFAC"
                app:boxStrokeColor="@color/borde_padel"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="#B2F814">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassReg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Repetir contraseña"
                android:textColorHint="#EDFFAC"
                app:boxStrokeColor="@color/borde_padel"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="#B2F814">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassReg2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Dirección Completa"
                android:textColorHint="#EDFFAC"
                app:boxStrokeColor="@color/borde_padel">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDireccion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPostalAddress"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Código Postal (CP)"
                android:textColorHint="#EDFFAC"
                app:boxStrokeColor="@color/borde_padel">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCP"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Método de Pago Preferido"
                android:textColorHint="#EDFFAC"
                app:boxStrokeColor="@color/borde_padel">

                <AutoCompleteTextView
                    android:id="@+id/dropdownPago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSecPadel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="2. PERFIL DE PÁDEL"
            android:textColor="#EDFFAC"
            android:textSize="25dp"

            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/llPersonales" />

        <LinearLayout
            android:id="@+id/llPadel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@+id/tvSecPadel">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nivel Inicial"
                    android:textColor="#EDFFAC"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/ivInfoNivel"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="#B2F814" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0"
                    android:textColor="#EDFFAC"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderNivel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:stepSize="0.01"
                    android:value="3.5"
                    android:valueFrom="0.0"
                    android:valueTo="7.0"
                    app:thumbColor="#B2F814"
                    app:trackColorActive="#B2F814"
                    app:trackColorInactive="#EDFFAC" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7.0"
                    android:textColor="#EDFFAC"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRestarNivel"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:text="-"
                    android:textColor="#EDFFAC"
                    android:textSize="24sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="#B2F814" />

                <TextView
                    android:id="@+id/tvValorNivel"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Nivel: 3.50"
                    android:textAlignment="center"
                    android:textColor="#EDFFAC"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSumarNivel"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:text="+"
                    android:textColor="#EDFFAC"
                    android:textSize="24sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="#B2F814" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Posición en la pista:"
                android:textColor="#EDFFAC" />

            <RadioGroup
                android:id="@+id/rgPosicionPadel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbDrive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#EDFFAC"
                    android:text="Drive (Derecha)"
                    android:textColor="#B2F814" />

                <RadioButton
                    android:id="@+id/rbReves"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:buttonTint="#EDFFAC"
                    android:text="Revés (Izquierda)"
                    android:textColor="#B2F814" />
            </RadioGroup>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Pista o Club Favorito"
                android:textColorHint="#EDFFAC"
                app:boxStrokeColor="@color/borde_padel">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPista"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="#EDFFAC" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSecDardos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:textSize="25dp"
            android:text="3. PERFIL DE DARDOS"
            android:textColor="#FF848E"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/llPadel" />

        <LinearLayout
            android:id="@+id/llDardos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@+id/tvSecDardos">

            <CheckBox
                android:id="@+id/cbTieneDiana"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#088C00"
                android:textSize="16dp"
                android:text="¿Tienes diana propia en casa?"
                android:textColor="#DC0101" />

            <RadioGroup
                android:id="@+id/rgTipoDiana"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:visibility="gone">

                <RadioButton
                    android:id="@+id/rbDianaPelo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#088C00"
                    android:textSize="16dp"

                    android:text="Diana de Pelo (Clásica)"
                    android:textColor="#DC0101" />

                <RadioButton
                    android:id="@+id/rbDianaElectronica"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#088C00"
                    android:textSize="16dp"
                    android:text="Diana Electrónica"
                    android:textColor="#DC0101" />

                <RadioButton
                    android:id="@+id/rbDianaAmbas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#088C00"
                    android:textSize="16dp"

                    android:text="Tengo de las dos"
                    android:textColor="#DC0101" />
            </RadioGroup>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCrearCuentaDef"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="32dp"
            android:text="CREAR CUENTA DEFINITIVA"
            android:textColor="#0D0D0C"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#B2F814"
            app:cornerRadius="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/llDardos" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>