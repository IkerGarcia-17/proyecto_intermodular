<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla de recuperación de contraseña. Mismo estilo oscuro + verde lima que el Login -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_padel_oscuro"
    android:padding="24dp">

    <!-- Logo de la app centrado arriba, igual que en el Login -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvLogoRecuperar"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginTop="48dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/fondo_tarjeta"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivLogoRecuperar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Título destacado de la pantalla -->
    <TextView
        android:id="@+id/tvTituloRecuperar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Recuperar contraseña"
        android:textColor="@color/verde_lima_brillante"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cvLogoRecuperar" />

    <!-- Texto explicativo del proceso de recuperación -->
    <TextView
        android:id="@+id/tvExplicacion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Introduce el correo electrónico de tu cuenta y te enviaremos un enlace para restablecer tu contraseña de forma segura."
        android:textAlignment="center"
        android:textColor="@color/texto_gris"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloRecuperar" />

    <!-- Campo de correo con el mismo estilo del Login -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilCorreoRecuperar"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:hint="Correo electrónico"
        android:textColorHint="@color/verde_lima_suave"
        app:hintTextColor="@color/verde_lima"
        app:boxStrokeColor="@color/borde_padel"
        app:boxStrokeWidth="2dp"
        app:boxStrokeWidthFocused="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvExplicacion">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCorreoRecuperar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:textColor="@color/white" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Botón principal de envío con el verde lima de la app -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEnviarEmail"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:text="ENVIAR ENLACE"
        android:textColor="@color/fondo_oscuro"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/verde_lima"
        app:cornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tilCorreoRecuperar" />

    <!-- Botón secundario de texto para volver al Login -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVolverLogin"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="← Volver al Login"
        android:textColor="@color/verde_lima_suave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnEnviarEmail" />

</androidx.constraintlayout.widget.ConstraintLayout>
