<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#232222"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivLogoRecuperar"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="32dp"
        android:src="@mipmap/ic_launcher"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvExplicacion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Introduce el correo electrónico de tu cuenta y te enviaremos un enlace para restablecer tu contraseña de forma segura."
        android:textAlignment="center"
        android:textColor="#A0A0A0"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivLogoRecuperar" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilCorreoRecuperar"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:hint="Correo electrónico"
        android:textColorHint="#A0A0A0"
        app:boxStrokeColor="#00E676"
        app:layout_constraintTop_toBottomOf="@+id/tvExplicacion">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCorreoRecuperar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:textColor="#FFFFFF" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEnviarEmail"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:text="ENVIAR ENLACE"
        android:textColor="#121212"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#00E676"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@+id/tilCorreoRecuperar" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVolverLogin"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Volver al Login"
        android:textColor="#A0A0A0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnEnviarEmail" />

</androidx.constraintlayout.widget.ConstraintLayout>