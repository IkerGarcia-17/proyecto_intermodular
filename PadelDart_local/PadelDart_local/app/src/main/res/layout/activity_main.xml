<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla de login. Usa el fondo oscuro con textura de pádel definido en drawable -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_padel_oscuro"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:minHeight="700dp">

        <!-- Botón X para cerrar la app por completo, en la esquina superior derecha -->
        <ImageView
            android:id="@+id/btnCerrarApp"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="20dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Cerrar app"
            app:tint="@color/verde_lima"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logo de la app en una tarjeta con bordes redondeados -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvLogoContainer"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/fondo_tarjeta"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnCerrarApp">

            <ImageView
                android:id="@+id/ivLogoLogin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/pepe"
                android:contentDescription="Logo PadelDart" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Nombre de la app bajo el logo -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="PadelDart"
            android:textColor="@color/verde_lima_brillante"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cvLogoContainer" />

        <!-- Subtítulo de bienvenida -->
        <TextView
            android:id="@+id/tvSubtituloLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tu espacio de pádel y dardos"
            android:textColor="@color/verde_lima_suave"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvAppName" />

        <!-- Campo de correo electrónico con estilo outlined verde -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCorreoLogin"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:hint="Correo electrónico"
            android:textColorHint="@color/verde_lima_suave"
            app:boxStrokeColor="@color/borde_padel"
            app:boxStrokeWidth="2dp"
            app:boxStrokeWidthFocused="3dp"
            app:hintTextColor="@color/verde_lima"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvSubtituloLogin">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCorreoLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textColor="@color/white"
                android:textColorHint="@color/verde_lima_suave" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo de contraseña con botón de ojo para mostrarla/ocultarla -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPasswordLogin"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Contraseña"
            android:textColorHint="@color/verde_lima_suave"
            app:hintTextColor="@color/verde_lima"
            app:boxStrokeColor="@color/borde_padel"
            app:boxStrokeWidth="2dp"
            app:boxStrokeWidthFocused="3dp"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/verde_lima"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tilCorreoLogin">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPasswordLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/white"
                android:textColorHint="@color/verde_lima_suave" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Fila: Recordar usuario (alineado a la derecha) -->
        <CheckBox
            android:id="@+id/cbRecordarUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/login_recordar"
            android:textColor="@color/verde_lima_suave"
            android:textSize="13sp"
            android:buttonTint="@color/verde_lima"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tilPasswordLogin" />

        <!-- Botón principal de login con el verde lima como fondo -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="@string/login_btn_entrar"
            android:textColor="@color/fondo_oscuro"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            app:backgroundTint="@color/verde_lima"
            app:cornerRadius="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cbRecordarUsuario" />

        <!-- Botón secundario de Google con borde y sin relleno -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoogle"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Continuar con Google"
            android:textColor="@color/verde_lima_claro"
            app:cornerRadius="10dp"
            app:strokeColor="@color/verde_lima_claro"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnLogin" />

        <!-- Link de recuperación de contraseña -->
        <TextView
            android:id="@+id/tvOlvidePassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="¿Has olvidado tu contraseña?"
            android:textColor="@color/verde_lima_suave"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnGoogle" />

        <!-- Link de registro: texto en verde lima más llamativo -->
        <TextView
            android:id="@+id/tvCrearCuenta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="32dp"
            android:text="No tengo cuenta. ¡Registrarme!"
            android:textColor="@color/verde_lima"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvOlvidePassword"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
