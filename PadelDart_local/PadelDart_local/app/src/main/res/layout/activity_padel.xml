<?xml version="1.0" encoding="utf-8"?>
<!-- Hub del módulo de Pádel: acceso al chat de amigos y al tablón de zona -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/fondo_padel_oscuro">

    <!-- Cabecera con botón atrás y título del módulo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAtras"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:text=""
            app:icon="@drawable/ic_arrow_back"
            app:iconSize="22dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/verde_lima"
            app:strokeColor="@color/verde_lima"
            app:strokeWidth="2dp"
            app:cornerRadius="22dp"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="@string/btn_atras" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎾  Pádel"
            android:textColor="@color/verde_lima_brillante"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Separador bajo la cabecera -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2A" />

    <!-- Contenido desplazable por si la pantalla es pequeña -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Tarjeta de Chat con Amigos -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardChatAmigos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/fondo_tarjeta">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Icono + título en la misma fila -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬"
                            android:textSize="32sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="@string/padel_chat_amigos"
                            android:textColor="@color/verde_lima"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/verde_lima"
                            android:textSize="28sp" />

                    </LinearLayout>

                    <!-- Descripción del apartado -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Habla con otros jugadores para quedar y organizar partidas. Mensajes directos y privados."
                        android:textColor="@color/texto_gris"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Tarjeta de Zona Provincial -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardZona"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/fondo_tarjeta">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📌"
                            android:textSize="32sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="@string/padel_zona"
                            android:textColor="@color/verde_lima"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/verde_lima"
                            android:textSize="28sp" />

                    </LinearLayout>

                    <!-- Tipos de publicaciones posibles -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Tablón de anuncios de tu provincia. Busca o crea partidas, compra/vende palas y solicita u ofrece clases."
                        android:textColor="@color/texto_gris"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />

                    <!-- Chips de categorías (meramente informativos) -->
                    <com.google.android.flexbox.FlexboxLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:flexWrap="wrap"
                        app:flexDirection="row">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Partidas"
                            android:textColor="@color/fondo_oscuro"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="#94D500"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Palas"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="#2196F3"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dar clases"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="#FF9800"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Buscar clases"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="#9C27B0"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />

                    </com.google.android.flexbox.FlexboxLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
