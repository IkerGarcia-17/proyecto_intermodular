<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla principal: saludo al usuario y acceso a los dos módulos de la app -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_padel_oscuro"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Foto de perfil circular del usuario.
             Si no tiene foto, muestra la inicial del nombre sobre fondo verde. -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFotoMain"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="48dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/fondo_tarjeta"
            app:strokeColor="@color/verde_lima"
            app:strokeWidth="2dp">

            <!-- Imagen real si el usuario eligió foto en el registro o perfil -->
            <ImageView
                android:id="@+id/imgFotoMain"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="@string/drawer_perfil" />

            <!-- Inicial del nombre como fallback cuando no hay foto -->
            <TextView
                android:id="@+id/tvInicialMain"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="?"
                android:textColor="@color/verde_lima"
                android:textSize="36sp"
                android:textStyle="bold" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Saludo personalizado con el nombre del usuario -->
        <TextView
            android:id="@+id/tvSaludoUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/main_bienvenido"
            android:textColor="@color/verde_lima_brillante"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Categoría de pádel del usuario -->
        <TextView
            android:id="@+id/tvCategoriaUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/verde_lima_suave"
            android:textSize="14sp"
            android:gravity="center" />

        <!-- Línea separadora decorativa -->
        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:background="@color/verde_lima" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="@string/main_que_hacer"
            android:textColor="@color/verde_lima_suave"
            android:textSize="16sp"
            android:gravity="center" />

        <!-- Tarjeta del módulo de Pádel, navega a PadelActivity -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPadel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/fondo_tarjeta">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:minHeight="110dp">

                <!-- Círculo de fondo para el icono -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="28dp"
                    app:cardBackgroundColor="#2094D500"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="🎾"
                        android:textSize="26sp"
                        android:gravity="center" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Texto del módulo de pádel -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/main_padel"
                        android:textColor="@color/verde_lima"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/main_padel_desc"
                        android:textColor="@color/texto_gris"
                        android:textSize="13sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/verde_lima"
                    android:textSize="28sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Tarjeta del módulo de Dardos -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDardos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/fondo_tarjeta">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:minHeight="110dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="28dp"
                    app:cardBackgroundColor="#2094D500"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="🎯"
                        android:textSize="26sp"
                        android:gravity="center" />

                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/main_dardos"
                        android:textColor="@color/verde_lima"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/main_dardos_desc"
                        android:textColor="@color/texto_gris"
                        android:textSize="13sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/verde_lima"
                    android:textSize="28sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Espacio inferior para no quedar pegado al borde -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>

</ScrollView>
