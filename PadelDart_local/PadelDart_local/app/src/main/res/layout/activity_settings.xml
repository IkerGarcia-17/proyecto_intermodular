<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla de ajustes: actualmente permite cambiar el idioma de la app.
     Usa un NestedScrollView para ser compatible con pantallas pequeñas. -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cabecera con botón atrás y título -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="20dp"
            android:paddingBottom="16dp"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:background="@color/fondo_tarjeta">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAtrasSettings"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text=""
                app:icon="@drawable/ic_arrow_back"
                app:iconSize="22dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/verde_lima"
                app:strokeColor="@color/verde_lima"
                app:strokeWidth="2dp"
                app:cornerRadius="22dp"
                android:backgroundTint="@android:color/transparent"
                android:contentDescription="@string/btn_atras" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_titulo"
                android:textColor="@color/verde_lima_brillante"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />

            <!-- Ícono de ajustes decorativo a la derecha -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️"
                android:textSize="22sp"
                android:layout_marginEnd="4dp" />

        </LinearLayout>

        <!-- Sección: Idioma -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_idioma"
            android:textColor="@color/verde_lima"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <!-- Tarjeta Español -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEspanol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/fondo_tarjeta"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/verde_lima"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <!-- Radio button para selección de idioma -->
                <android.widget.RadioButton
                    android:id="@+id/rbEspanol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/verde_lima"
                    android:checked="true" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="@string/settings_espanol"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🇪🇸"
                    android:textSize="22sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tarjeta English -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEnglish"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/fondo_tarjeta"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/fondo_tarjeta_claro"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <android.widget.RadioButton
                    android:id="@+id/rbEnglish"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/verde_lima"
                    android:checked="false" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="@string/settings_english"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🇬🇧"
                    android:textSize="22sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botón guardar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardarSettings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_margin="16dp"
            android:layout_marginTop="24dp"
            android:text="@string/settings_guardar"
            android:textColor="@color/fondo_oscuro"
            android:textStyle="bold"
            app:backgroundTint="@color/verde_lima"
            app:cornerRadius="10dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
