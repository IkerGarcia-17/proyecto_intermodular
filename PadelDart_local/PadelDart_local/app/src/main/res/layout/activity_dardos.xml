<?xml version="1.0" encoding="utf-8"?>
<!-- Hub del módulo de dardos: elige entre PvP (humano vs humano) y PvE (vs CPU).
     Diseñado para ser visualmente impactante: diana grande, tarjetas limpias. -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="32dp"
        android:gravity="center_horizontal">

        <!-- ── DIANA GRANDE ──────────────────────────────────────────────────── -->
        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/diana_grande"
            android:contentDescription="Diana de dardos" />

        <!-- Título principal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/dardos_titulo"
            android:textColor="@color/verde_lima_brillante"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:gravity="center" />

        <!-- Subtítulo / reglas en una línea -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="36dp"
            android:text="@string/dardos_reglas"
            android:textColor="@color/texto_gris"
            android:textSize="12sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3" />

        <!-- ── TARJETA PvP ────────────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPvP"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="14dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/fondo_tarjeta"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            app:strokeColor="#1E94D500"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <!-- Banda izquierda verde -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="18dp"
                    android:background="@color/verde_lima" />

                <!-- Emoji + textos -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👥"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dardos_pvp"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/dardos_pvp_desc"
                        android:textColor="@color/texto_gris"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Flecha derecha -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/verde_lima"
                    android:textSize="32sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── TARJETA PvE ────────────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPvE"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="14dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/fondo_tarjeta"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            app:strokeColor="#1E2196F3"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <!-- Banda izquierda azul (CPU) -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="18dp"
                    android:background="#2196F3" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤖"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dardos_pve"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/dardos_elige_dificultad"
                        android:textColor="@color/texto_gris"
                        android:textSize="12sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#2196F3"
                    android:textSize="32sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── PILLS DE DIFICULTAD (informativo) ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dardos_facil"
                android:textColor="#121212"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="#4CAF50"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dardos_normal"
                android:textColor="#121212"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="#FFC107"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dardos_dificil"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="#FF5722"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dardos_perfecto"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="#9C27B0"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
